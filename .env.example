# ログインパスワード（自宅・社内で共通）
VAULT_PASSWORD=your-strong-password-here

# セッション署名用（32文字以上のランダム文字列）
SESSION_SECRET=change-this-to-a-long-random-string

# Vercel Blob（本番必須 — Storage をプロジェクトに接続すると自動設定）
# 未設定時はローカル開発のみ packages/ に保存
# BLOB_READ_WRITE_TOKEN=

# Blob ストア作成時の設定に合わせる（Private ストアなら private、Public なら public）
# NEXT_PUBLIC_BLOB_ACCESS=private
